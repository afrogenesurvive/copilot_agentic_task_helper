{
  "name": "copilot_agentic_task_helper",
  "version": "1.0.0",
  "private": true,
  "description": "Remote Collaborator Chat — Trello-powered chat interface for GitHub Copilot agent interactions",
  "scripts": {
    "logs:view": "cat logs/2026-05-31.log",
    "mcp:gmail": "node mcp/gmail/index.js",
    "mcp:trello": "node mcp/trello/index.js",
    "mcp:drive": "node mcp/drive/index.js",
    "mcp:calendar": "node mcp/calendar/index.js",
    "mcp:web-search": "node mcp/web-search/index.js",
    "mcp:webhook": "node mcp/webhook-server/index.js",
    "setup:drive-watch": "node mcp/webhook-server/scripts/setup-drive-watch.js",
    "setup:calendar-watch": "node mcp/webhook-server/scripts/setup-calendar-watch.js",
    "setup:calendar-ref": "node scripts/setup-calendar-ref.js",
    "setup:drive-ref": "node scripts/setup-drive-ref.js",
    "setup:gmail-auth": "node scripts/gmail-auth.mjs",
    "setup:gmail-watch": "node mcp/webhook-server/scripts/setup-gmail-watch.js",
    "setup:trello-webhook": "node mcp/webhook-server/scripts/setup-trello-webhook.js",
    "update:endpoint": "node mcp/webhook-server/scripts/update-push-endpoint.js",
    "update:pubsub": "node mcp/webhook-server/scripts/update-pubsub-endpoint.js",
    "webhook:check-watch": "node mcp/webhook-server/scripts/check-gmail-watch.js",
    "webhook:start": "node mcp/webhook-server/index.js",
    "webhook:start:tunnel": "concurrently \"node mcp/webhook-server/index.js\" \"bash mcp/webhook-server/scripts/setup-tunnel.sh\"",
    "webhook:setup": "bash mcp/webhook-server/scripts/start-webhook.sh",
    "webhook:tunnel": "bash mcp/webhook-server/scripts/setup-tunnel.sh",
    "webhook:restart": "bash mcp/webhook-server/scripts/restart-webhook.sh",
    "webhook:restart:quick": "bash mcp/webhook-server/scripts/restart-webhook.sh --quick",
    "webhook:dev": "WEBHOOK_DEV_WATCH=true bash -c 'while true; do node mcp/webhook-server/index.js; echo; echo \"⚡ Restarting...\"; sleep 1; done'",
    "webhook:start-all": "bash mcp/webhook-server/scripts/start-all.sh",
    "runner:start": "node mcp/agent-runner/index.js",
    "runner:stop": "kill $(cat mcp/agent-runner/.runner.pid 2>/dev/null) 2>/dev/null; echo 'Runner stopped'",
    "runner:status": "ps aux | grep 'agent-runner' | grep -v grep || echo 'Runner not running'"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "express": "^4.21.0",
    "googleapis": "^144.0.0",
    "node-fetch": "^3.3.2"
  }
}
